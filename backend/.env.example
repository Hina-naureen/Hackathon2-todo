# backend/.env.example — copy to backend/.env and fill in values
# Never commit backend/.env (it is gitignored)

# ── Required ──────────────────────────────────────────────────────────────────

# Neon PostgreSQL connection string (get from https://neon.tech dashboard)
DATABASE_URL=postgresql+psycopg2://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Shared JWT secret — must match frontend BETTER_AUTH_SECRET exactly
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
BETTER_AUTH_SECRET=your-64-char-hex-secret-here

# ── Optional ──────────────────────────────────────────────────────────────────

# OpenAI API key — if absent, agent runs in local keyword-simulation mode
OPENAI_API_KEY=sk-...

# CORS origins (default: http://localhost:3000)
# ALLOWED_ORIGINS=http://localhost:3000

# Dapr — auto-injected by sidecar in K8s, set manually only for local Dapr run
# DAPR_HTTP_PORT=3500
