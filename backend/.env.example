# backend/.env.example
# Copy this file to backend/.env and fill in real values.
# Never commit .env to git.

# ── Database ────────────────────────────────────────────────────────────────
# Neon DB (production / staging):
#   1. Go to console.neon.tech → your project → Connection Details
#   2. Select "psycopg2" driver → copy the connection string
#   3. Paste below (it includes ?sslmode=require automatically)
#
# DATABASE_URL=postgresql+psycopg2://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require
#
# Neon Pooler (recommended for high-concurrency deployments):
#   Use port 6432 and the pooler hostname (ends in -pooler.region.aws.neon.tech)
#   Add &pgbouncer=true to the query string.
#
# DATABASE_URL=postgresql+psycopg2://<user>:<password>@<host>-pooler.neon.tech:6432/<dbname>?sslmode=require&pgbouncer=true
#
# SQLite (local dev only — created automatically when DATABASE_URL is not set):
# DATABASE_URL=sqlite:///./dev.db
DATABASE_URL=

# ── Authentication ───────────────────────────────────────────────────────────
# Must match BETTER_AUTH_SECRET in frontend/.env.local.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BETTER_AUTH_SECRET=

# ── Development helpers ──────────────────────────────────────────────────────
# Set to "true" to bypass JWT validation in local development ONLY.
# NEVER set this in production.
AUTH_DISABLED=false

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
# ALLOWED_ORIGINS=http://localhost:3000,https://your-prod-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Phase III — AI Chat ──────────────────────────────────────────────────────
# OpenAI API key for the TaskAgent (gpt-4o-mini).
# Without this key the agent falls back to a local keyword simulation —
# the app remains fully functional but returns canned replies instead of
# real LLM responses.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
