# frontend/.env.example — copy to frontend/.env.local and fill in values
# Never commit frontend/.env.local (it is gitignored)

# ── Required ──────────────────────────────────────────────────────────────────

# Must match backend BETTER_AUTH_SECRET exactly (same token for JWT verification)
BETTER_AUTH_SECRET=your-64-char-hex-secret-here

# Backend API URL (seen from the browser, not from Docker network)
# Local dev:   http://localhost:8000
# Minikube:    http://todo.local
# DOKS:        https://todo.example.com
NEXT_PUBLIC_API_URL=http://localhost:8000
